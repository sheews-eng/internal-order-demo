# Firebase Admin — path to service account JSON (download from Firebase Console)
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
# Or absolute path, e.g. C:\secrets\internal-orders-sa.json

# Firebase RTDB URL (must match the web app databaseURL)
FIREBASE_DATABASE_URL=https://internal-orders-765dd-default-rtdb.asia-southeast1.firebasedatabase.app

# ---- AutoCount Integrator / local API ----
# Set to 1 to push sample items without calling AutoCount (for UI testing)
AUTOCOUNT_MOCK=1

# Base URL of Integrator / local stock API (no trailing slash)
AUTOCOUNT_BASE_URL=http://127.0.0.1:8080

# Path that returns stock item list (adjust to your vendor docs)
AUTOCOUNT_STOCK_PATH=/api/stock/items

# Auth: API key sent as header (name configurable)
AUTOCOUNT_API_KEY=
AUTOCOUNT_API_KEY_HEADER=X-Api-Key

# Optional Basic auth (leave blank if unused)
AUTOCOUNT_BASIC_USER=
AUTOCOUNT_BASIC_PASS=

# Field mapping: JSON keys in Integrator response → our schema
# Defaults match common names; change if your API differs
AUTOCOUNT_FIELD_CODE=ItemCode
AUTOCOUNT_FIELD_DESC=Description
AUTOCOUNT_FIELD_PRICE=Price
AUTOCOUNT_FIELD_UOM=UOM

# How often to sync when running `npm start` (minutes)
SYNC_INTERVAL_MINUTES=15
